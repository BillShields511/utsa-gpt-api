import traceback

from firebase_script import load_documents
from gemini_agent import RAGAgent

_COLLECTION = "game"
_EXIT_COMMAND = "exit"


def main() -> None:
    try:
        documents = load_documents(_COLLECTION)
        if not documents:
            print("No documents found in the collection.")
            return
        print(f"Documents loaded: {len(documents)}")

        agent = RAGAgent()

        contents = [doc.text for doc in documents]
        vectors = agent.embed(contents)
        print(f"Indexed {len(vectors)} documents.")

        while True:
            question = input(
                f"\nAsk a question about the NFL schedule "
                f"(or type '{_EXIT_COMMAND}' to quit): "
            ).strip()

            if not question:
                continue
            if question.lower() == _EXIT_COMMAND:
                break

            answer, _ = agent.answer(question, contents, vectors, verbose=False)
            print("\nGemini Agent Response:", answer)

    except Exception:
        traceback.print_exc()


if __name__ == "__main__":
    main()