from firebase_script import llamaLoad
from gemini_agent import embedding, rag_response

def main():
    try:
        document = llamaLoad("game")
        print("Documents loaded:", len(document))
        if not document:
            print("No documents found in the collection.")
            return
        
        # Build contents and vectors ONCE before the question loop
        contents = [doc.text for doc in document]
        vectors = embedding(contents)
        print(f"Indexed {len(vectors)} documents")
        
        while True:
            question = input("\nAsk a question about the NFL schedule (or type 'exit' to quit): ")
            if question.lower() == "exit":
                break
            
            answer = rag_response(question, contents, vectors)
            print("\nGemini Agent Response:", answer)

    except Exception as e:
        import traceback
        traceback.print_exc()

if __name__ == "__main__":
    main()